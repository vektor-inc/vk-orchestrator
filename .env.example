# .env は「秘密情報」だけを置く場所です。
# それ以外の設定は config.json（config.example.json をコピー）に書きます。
# 優先順位: 環境変数(.env) > config.json > 既定値。

# GitHub Personal Access Token（必要スコープ: repo）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- 以下は任意（config.json の値を一時的に上書きしたいときだけ）---
# GITHUB_OWNER=your-org
# GITHUB_REPO=task-queue
# SOURCE_ORG=your-org
# QUEUE_LABEL=task-queue
# VK_TERMINALS_PORT=13847
# VK_TERMINALS_HOST=127.0.0.1
# POLL_INTERVAL_MS=60000
# WATCHDOG_IDLE_MS=10800000
# ASSIGNEE_FILTER=your-github-login
