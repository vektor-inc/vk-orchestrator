{
  "name": "vk-orchestrator",
  "version": "0.11.0",
  "description": "Reusable orchestrator that drives Claude sessions in VK Terminals from a GitHub issues-based task queue.",
  "type": "module",
  "license": "GPL-2.0-only",
  "bin": {
    "vk-orchestrator": "bin/vk-orchestrator.js"
  },
  "main": "src/engine/index.js",
  "scripts": {
    "start": "node bin/vk-orchestrator.js up",
    "up": "node bin/vk-orchestrator.js up",
    "orchestrator": "node bin/vk-orchestrator.js start",
    "run-once": "node bin/vk-orchestrator.js start --once",
    "check-status": "node bin/vk-orchestrator.js check-status",
    "unblock": "node bin/vk-orchestrator.js unblock",
    "setup:terminals": "node bin/vk-orchestrator.js setup-terminals",
    "setup:agents": "node bin/vk-orchestrator.js setup-agents",
    "bump:terminals": "node scripts/bump-vk-terminals.mjs",
    "setup:labels": "node src/engine/ensure-task-queue-label.mjs",
    "setup:queue-labels": "node src/engine/ensure-task-queue-label.mjs --status",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "dotenv": "^16.4.5"
  },
  "optionalDependencies": {
    "@electron/rebuild": "^3.6.0",
    "vk-terminals": "git+https://github.com/vektor-inc/vk-terminals.git#1.15.0"
  }
}
